{
  "version": "0.8.7",
  "commands": {
    "bundle": {
      "id": "bundle",
      "description": "Builds all the sources in the repository and generates a versioning file",
      "strict": true,
      "pluginName": "@paperback/toolchain",
      "pluginAlias": "@paperback/toolchain",
      "pluginType": "core",
      "aliases": [],
      "flags": {
        "help": {
          "name": "help",
          "type": "boolean",
          "char": "h",
          "description": "Show CLI help.",
          "allowNo": false
        },
        "folder": {
          "name": "folder",
          "type": "option",
          "description": "Subfolder to output to",
          "required": false,
          "multiple": false
        },
        "use-node-fs": {
          "name": "use-node-fs",
          "type": "boolean",
          "description": "For more info, check https://github.com/Paperback-iOS/paperback-toolchain/pull/4#issuecomment-1791566399",
          "required": false,
          "allowNo": false
        }
      },
      "args": {}
    },
    "logcat": {
      "id": "logcat",
      "description": "describe the command here",
      "strict": true,
      "pluginName": "@paperback/toolchain",
      "pluginAlias": "@paperback/toolchain",
      "pluginType": "core",
      "aliases": [],
      "flags": {
        "ip": {
          "name": "ip",
          "type": "option",
          "multiple": false,
          "default": "localhost"
        },
        "port": {
          "name": "port",
          "type": "option",
          "multiple": false,
          "default": 27015
        }
      },
      "args": {}
    },
    "migrate": {
      "id": "migrate",
      "description": "Migrate 0.7 sources to 0.8",
      "strict": true,
      "pluginName": "@paperback/toolchain",
      "pluginAlias": "@paperback/toolchain",
      "pluginType": "core",
      "aliases": [],
      "examples": [
        "<%= config.bin %> <%= command.id %>"
      ],
      "flags": {},
      "args": {}
    },
    "serve": {
      "id": "serve",
      "description": "Build the sources and start a local server",
      "strict": true,
      "pluginName": "@paperback/toolchain",
      "pluginAlias": "@paperback/toolchain",
      "pluginType": "core",
      "aliases": [],
      "flags": {
        "help": {
          "name": "help",
          "type": "boolean",
          "char": "h",
          "description": "Show CLI help.",
          "allowNo": false
        },
        "port": {
          "name": "port",
          "type": "option",
          "char": "p",
          "multiple": false,
          "default": 8080
        },
        "watch": {
          "name": "watch",
          "type": "boolean",
          "char": "w",
          "description": "Rebuild sources on typescript file changes within directory",
          "allowNo": false
        },
        "use-node-fs": {
          "name": "use-node-fs",
          "type": "boolean",
          "description": "For more info, check https://github.com/Paperback-iOS/paperback-toolchain/pull/4#issuecomment-1791566399",
          "required": false,
          "allowNo": false
        }
      },
      "args": {}
    },
    "test": {
      "id": "test",
      "description": "describe the command here",
      "strict": true,
      "pluginName": "@paperback/toolchain",
      "pluginAlias": "@paperback/toolchain",
      "pluginType": "core",
      "aliases": [],
      "flags": {
        "ip": {
          "name": "ip",
          "type": "option",
          "multiple": false
        },
        "port": {
          "name": "port",
          "type": "option",
          "multiple": false,
          "default": 27015
        },
        "use-node-fs": {
          "name": "use-node-fs",
          "type": "boolean",
          "description": "For more info, check https://github.com/Paperback-iOS/paperback-toolchain/pull/4#issuecomment-1791566399",
          "required": false,
          "allowNo": false
        }
      },
      "args": {
        "source": {
          "name": "source",
          "description": "(optional) The source to test",
          "required": false
        }
      }
    }
  }
}